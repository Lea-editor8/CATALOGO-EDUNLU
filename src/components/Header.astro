---
interface Props {
    collections: string[];
    allCategories: string[];
}

const { collections, allCategories } = Astro.props;
---

<header
    class="bg-white border-b border-gray-200 sticky top-0 z-50 py-4 shadow-sm"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Fila Superior: Título y Búsqueda -->
        <div
            class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4"
        >
            <h1 class="text-2xl font-bold text-slate-800">Colecciones</h1>

            <div
                class="flex flex-col sm:flex-row items-center gap-4 w-full md:max-w-2xl"
            >
                <!-- Buscador -->
                <div class="relative w-full">
                    <input
                        type="search"
                        id="searchInput"
                        placeholder="Buscar por título o autor..."
                        class="w-full pl-4 pr-10 py-2 border border-gray-200 rounded-full focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 text-sm transition-all"
                    />
                    <div
                        class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none"
                    >
                        <svg
                            class="h-4 w-4 text-gray-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                            ></path>
                        </svg>
                    </div>
                </div>

                <!-- Filtro de Tema (Movido aquí) -->
                <div class="flex items-center gap-2 shrink-0">
                    <span
                        class="text-xs font-semibold text-gray-400 uppercase tracking-widest"
                        >Tema:</span
                    >
                    <div class="relative min-w-[180px]">
                        <select
                            id="categoryFilters"
                            class="w-full appearance-none bg-white border border-gray-200 text-gray-700 py-2 px-3 pr-8 rounded-full leading-tight focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 text-xs cursor-pointer transition-all hover:border-gray-300 shadow-sm"
                        >
                            <option value="all">Todos los temas</option>
                            {
                                allCategories.map((category) => (
                                    <option value={category}>{category}</option>
                                ))
                            }
                        </select>
                        <div
                            class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400"
                        >
                            <svg
                                class="fill-current h-3 w-3"
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 7.293 8.122 5.879 9.538z"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fila Inferior: Filtros y Orden -->
        <div
            class="flex flex-col lg:flex-row lg:items-center justify-between gap-4"
        >
            <!-- Filtros: Colección y Tema -->
            <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
                <div class="flex flex-wrap items-center gap-2">
                    <div id="collectionFilters" class="flex flex-wrap gap-2">
                        <button
                            data-collection="all"
                            class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 hover:bg-green-600 hover:text-white rounded transition font-medium"
                        >
                            Todos
                        </button>
                        {
                            collections.map((collection) => {
                                let hoverClass = "hover:bg-gray-200";
                                if (collection === "Ciencias")
                                    hoverClass =
                                        "hover:bg-[#E53935] hover:text-white";
                                else if (
                                    collection === "Sociedad en movimiento"
                                )
                                    hoverClass =
                                        "hover:bg-[#FDD835] hover:text-black";
                                else if (collection === "Aulas")
                                    hoverClass =
                                        "hover:bg-[#1976D2] hover:text-white";

                                return (
                                    <button
                                        data-collection={collection}
                                        class={`px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded transition font-medium ${hoverClass}`}
                                    >
                                        {collection}
                                    </button>
                                );
                            })
                        }
                        <button
                            data-collection=""
                            class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 hover:bg-slate-500 hover:text-white rounded transition font-medium"
                        >
                            s/n Colección
                        </button>
                    </div>
                </div>
            </div>

            <!-- Ordenamiento -->
            <div class="flex items-center gap-3">
                <span
                    class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >Ordenar por:</span
                >
                <div class="flex gap-2">
                    <button
                        id="sortAlpha"
                        data-sort="alpha"
                        class="px-4 py-1.5 text-xs bg-gray-100 text-gray-700 hover:bg-gray-200 rounded transition font-medium"
                    >
                        A-Z
                    </button>
                    <button
                        id="sortDate"
                        data-sort="date"
                        class="px-4 py-1.5 text-xs bg-green-600 text-white rounded transition font-medium active-sort"
                    >
                        Fecha
                    </button>
                    <button
                        id="resetFilters"
                        class="px-3 py-1.5 text-xs bg-red-50 text-red-600 hover:bg-red-100 rounded transition font-medium flex items-center gap-1 ml-2"
                        title="Limpiar todos los filtros"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3.5 w-3.5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                            ></path>
                        </svg>
                        Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>
</header>
