---
import { books, type Book } from "@data/libros";
import Image from "astro/components/Image.astro";

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/imagenes/libros/*.{jpeg,jpg,png,gif,webp}",
    { eager: true },
);

const booksForJs = books.map((b: Book) => {
    const imagePath = `/src/assets/imagenes/libros/${b.coverImage}`;
    return {
        ...b,
        coverImage: images[imagePath] ? images[imagePath].default.src : "",
    };
});
---

<section id="catalogo" class="min-h-screen flex flex-col bg-slate-200 pt-6">
    <div id="libraryMessage" class="max-w-7xl mx-auto px-4 py-2 w-full"></div>

    <!-- Mensaje cuando no hay resultados -->
    <div
        id="emptyLibraryMessage"
        class="hidden flex-1 flex-col items-center justify-center p-20 text-gray-500"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-16 w-16 text-gray-300 mb-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
            ></path>
        </svg>
        <p class="text-xl font-semibold text-gray-600">
            No se encontraron libros
        </p>
        <p class="text-sm mt-2">
            Intentá con otros filtros o términos de búsqueda
        </p>
    </div>

    <div
        id="book-grid"
        data-books={JSON.stringify(booksForJs)}
        class="flex-1 w-full max-w-full mx-auto grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 p-4 content-start"
    >
        {
            books.map((book: Book) => (
                <article
                    class="group flex flex-col h-full bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden cursor-pointer"
                    data-id={book.id}
                    data-title={book.title.toLowerCase()}
                    data-author={book.author.toLowerCase()}
                    data-collection={book.collection}
                    data-categories={JSON.stringify(book.category)}
                >
                    <div class="aspect-3/4 overflow-hidden bg-gray-100 flex items-center justify-center p-2">
                        <Image
                            src={
                                images[
                                    `/src/assets/imagenes/libros/${book.coverImage}`
                                ]?.default
                            }
                            alt={book.title}
                            width={200}
                            height={267}
                            class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105"
                        />
                    </div>
                    <div class="p-3 flex flex-col flex-1 gap-2">
                        <div class="flex-1">
                            <h3 class="text-sm font-semibold text-gray-800 line-clamp-2 leading-tight">
                                {book.title}
                            </h3>
                            <p class="text-xs text-gray-500 line-clamp-2 mt-1">
                                {book.author}
                            </p>
                        </div>
                        <div class="mt-2">
                            <button class="w-full py-1.5 px-3 bg-green-600 text-white text-xs font-medium rounded-md hover:bg-green-700 transition-colors flex items-center justify-center gap-1">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-3 w-3"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                    />
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                    />
                                </svg>
                                Ver
                            </button>
                        </div>
                    </div>
                </article>
            ))
        }
    </div>
    <script>
        import type { Book } from "@data/libros";

        const grid = document.getElementById("book-grid") as HTMLElement;
        const allBooks = JSON.parse(grid?.dataset?.books || "[]") as Book[];
        const searchInput = document.getElementById(
            "searchInput",
        ) as HTMLInputElement | null;
        const collectionFilters = document.getElementById(
            "collectionFilters",
        ) as HTMLElement | null;
        const categoryFilters = document.getElementById(
            "categoryFilters",
        ) as HTMLSelectElement | null;
        const sortAlpha = document.getElementById(
            "sortAlpha",
        ) as HTMLElement | null;
        const sortDate = document.getElementById(
            "sortDate",
        ) as HTMLElement | null;
        const resetFilters = document.getElementById(
            "resetFilters",
        ) as HTMLElement | null;
        const emptyMessage = document.getElementById(
            "emptyLibraryMessage",
        ) as HTMLElement | null;
        const filterToggle = document.getElementById(
            "filterToggle",
        ) as HTMLElement | null;
        const filterPanel = document.getElementById(
            "filterPanel",
        ) as HTMLElement | null;
        const filterBadge = document.getElementById(
            "filterBadge",
        ) as HTMLElement | null;
        const filterChevron = document.getElementById(
            "filterChevron",
        ) as HTMLElement | null;

        let currentCollection = "all";
        let currentSeries = "all";
        let currentCategory = "all";
        let currentSort = "date";
        let searchQuery = "";

        const articles = grid
            ? Array.from(grid.querySelectorAll("article"))
            : [];

        if (sortAlpha && sortDate) {
            sortAlpha.classList.add("bg-gray-100", "text-gray-700");
            sortDate.classList.remove("bg-gray-100", "text-gray-700");
            sortDate.classList.add("bg-green-600", "text-white");
        }

        function filterAndSort() {
            if (!grid || !emptyMessage) return;

            let filtered = [...allBooks];

            if (searchQuery) {
                const q = searchQuery.toLowerCase();
                filtered = filtered.filter(
                    (b) =>
                        b.title.toLowerCase().includes(q) ||
                        b.author.toLowerCase().includes(q),
                );
            }

            if (currentCollection !== "all") {
                filtered = filtered.filter(
                    (b) => (b.collection || "") === currentCollection,
                );
            }

            if (currentSeries !== "all") {
                filtered = filtered.filter(
                    (b) => (b.series || "") === currentSeries,
                );
            }

            if (currentCategory !== "all") {
                filtered = filtered.filter((b) =>
                    b.category.includes(currentCategory),
                );
            }

            if (currentSort === "alpha") {
                filtered.sort((a, b) => a.title.localeCompare(b.title));
            } else if (currentSort === "date") {
                filtered.sort(
                    (a, b) =>
                        new Date(b.publishDate).getTime() -
                        new Date(a.publishDate).getTime(),
                );
            }

            const filteredIds = new Set(filtered.map((b) => b.id));

            // Reordenar físicamente en el DOM y mostrar/ocultar
            filtered.forEach((book) => {
                const article = articles.find((a) => a.dataset.id === book.id);
                if (article) {
                    grid.appendChild(article);
                    article.style.display = "";
                }
            });

            // Ocultar los que no están en el filtro
            articles.forEach((article) => {
                const articleId = article.dataset.id;
                if (articleId && !filteredIds.has(articleId)) {
                    article.style.display = "none";
                }
            });

            if (filtered.length === 0) {
                emptyMessage.classList.remove("hidden");
                emptyMessage.classList.add("flex");
            } else {
                emptyMessage.classList.add("hidden");
                emptyMessage.classList.remove("flex");
            }

            updateFilterBadge();
        }

        const collectionColors: Record<string, { bg: string; text: string }> = {
            Ciencias: { bg: "bg-[#E53935]", text: "text-white" },
            "Sociedad en Movimiento": {
                bg: "bg-[#FDD835]",
                text: "text-black",
            },
            "Serie Historias de Vida": { bg: "bg-lime-500", text: "text-white" },
            "Aulas Universitarias": { bg: "bg-[#1976D2]", text: "text-white" },
            "": { bg: "bg-slate-500", text: "text-white" },
            all: { bg: "bg-green-600", text: "text-white" },
        };

        function resetAllFiltersUI() {
            searchQuery = "";
            if (searchInput) searchInput.value = "";

            currentCollection = "all";
            currentSeries = "all";
            document
                .querySelectorAll("#collectionFilters button")
                .forEach((btn) => {
                    const button = btn as HTMLElement;
                    button.classList.remove(
                        "bg-green-600",
                        "bg-[#E53935]",
                        "bg-[#FDD835]",
                        "bg-[#1976D2]",
                        "bg-slate-500",
                        "bg-lime-500",
                        "text-white",
                        "text-black",
                    );
                    button.classList.add("bg-gray-100", "text-gray-700");
                    if (
                        button.dataset.collection === "all" ||
                        button.dataset.series === "all"
                    ) {
                        if (button.dataset.collection === "all") {
                            button.classList.remove(
                                "bg-gray-100",
                                "text-gray-700",
                            );
                            button.classList.add("bg-green-600", "text-white");
                        }
                    }
                });

            currentCategory = "all";
            if (categoryFilters) categoryFilters.value = "all";

            currentSort = "date";
            document
                .querySelectorAll("#sortAlpha, #sortDate")
                .forEach((btn) => {
                    const button = btn as HTMLElement;
                    button.classList.remove("bg-green-600", "text-white");
                    button.classList.add("bg-gray-100", "text-gray-700");
                });

            if (sortDate) {
                sortDate.classList.remove("bg-gray-100", "text-gray-700");
                sortDate.classList.add("bg-green-600", "text-white");
            }

            filterAndSort();
            updateFilterBadge();
        }

        function updateFilterBadge() {
            if (!filterBadge) return;
            let count = 0;
            if (currentCollection !== "all") count++;
            if (currentSeries !== "all") count++;
            if (currentCategory !== "all") count++;

            if (count > 0) {
                filterBadge.classList.remove("hidden");
                filterBadge.textContent = String(count);
            } else {
                filterBadge.classList.add("hidden");
                filterBadge.textContent = "0";
            }
        }

        resetFilters?.addEventListener("click", resetAllFiltersUI);

        filterToggle?.addEventListener("click", () => {
            if (!filterPanel || !filterChevron) return;
            const isHidden = filterPanel.classList.contains("hidden");
            if (isHidden) {
                filterPanel.classList.remove("hidden");
                filterChevron.classList.add("rotate-180");
            } else {
                filterPanel.classList.add("hidden");
                filterChevron.classList.remove("rotate-180");
            }
        });

        collectionFilters?.addEventListener("click", (e) => {
            const button = (e.target as HTMLElement).closest("button");
            if (
                button &&
                (button.parentElement?.id === "collectionFilters" ||
                    button.parentElement?.parentElement?.id ===
                        "collectionFilters")
            ) {
                const collection = button.getAttribute("data-collection");
                const series = button.getAttribute("data-series");

                document
                    .querySelectorAll("#collectionFilters button")
                    .forEach((btn) => {
                        const b = btn as HTMLElement;
                        b.classList.remove(
                            "bg-green-600",
                            "bg-[#E53935]",
                            "bg-[#FDD835]",
                            "bg-[#1976D2]",
                            "bg-slate-500",
                            "bg-lime-500",
                            "text-white",
                            "text-black",
                        );
                        b.classList.add("bg-gray-100", "text-gray-700");
                    });

                if (series !== null) {
                    const activeColors =
                        collectionColors[series] || collectionColors["all"];
                    button.classList.remove("bg-gray-100", "text-gray-700");
                    button.classList.add(activeColors.bg, activeColors.text);
                    currentSeries = series;
                    currentCollection = "all";
                } else if (collection !== null) {
                    const activeColors =
                        collectionColors[collection] || collectionColors["all"];
                    button.classList.remove("bg-gray-100", "text-gray-700");
                    button.classList.add(activeColors.bg, activeColors.text);
                    currentCollection = collection;
                    currentSeries = "all";
                }

                filterAndSort();
            }
        });

        categoryFilters?.addEventListener("change", (e) => {
            const target = e.target as HTMLSelectElement;
            currentCategory = target.value;
            filterAndSort();
        });

        sortAlpha?.addEventListener("click", () => {
            document
                .querySelectorAll("#sortAlpha, #sortDate")
                .forEach((btn) => {
                    const button = btn as HTMLElement;
                    button.classList.remove("bg-green-600", "text-white");
                    button.classList.add("bg-gray-100", "text-gray-700");
                });
            if (sortAlpha) {
                sortAlpha.classList.remove("bg-gray-100", "text-gray-700");
                sortAlpha.classList.add("bg-green-600", "text-white");
            }
            currentSort = "alpha";
            filterAndSort();
        });

        sortDate?.addEventListener("click", () => {
            document
                .querySelectorAll("#sortAlpha, #sortDate")
                .forEach((btn) => {
                    const button = btn as HTMLElement;
                    button.classList.remove("bg-green-600", "text-white");
                    button.classList.add("bg-gray-100", "text-gray-700");
                });
            if (sortDate) {
                sortDate.classList.remove("bg-gray-100", "text-gray-700");
                sortDate.classList.add("bg-green-600", "text-white");
            }
            currentSort = "date";
            filterAndSort();
        });

        searchInput?.addEventListener("input", (e) => {
            const target = e.target as HTMLInputElement;
            searchQuery = target.value;
            filterAndSort();
        });

        articles.forEach((card) => {
            card.addEventListener("click", () => {
                const id = card.dataset.id;
                const book = allBooks.find((b) => b.id === id);
                if (book && book.targetUrl) {
                    window.open(book.targetUrl, "_blank");
                }
            });
        });

        filterAndSort();
    </script>
</section>
