---
import "swiper/css";
import "swiper/css/effect-coverflow";
import "swiper/css/pagination";

import type { ImageMetadata } from "astro";
import LayoutCarrusel from "@layouts/LayoutCarrusel.astro";
import { books, type Book } from "@data/libros";

const images = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/imagenes/libros/*.{jpeg,jpg,png,gif,webp}",
    { eager: true },
);

const collectionColors: Record<string, { bg: string; text: string }> = {
    Ciencias: { bg: "#E53935", text: "#ffffff" },
    "Sociedad en Movimiento": { bg: "#FDD835", text: "#000000" },
    "Aulas Universitarias": { bg: "#1976D2", text: "#ffffff" },
    "": { bg: "#64748b", text: "#ffffff" },
};

function getImageSrc(coverImage: string): string {
    const mod = images[`/src/assets/imagenes/libros/${coverImage}`];
    return mod?.default?.src ?? "";
}

function getCollectionStyle(collection: string): string {
    const c = collectionColors[collection] ?? collectionColors[""];
    return `background-color:${c.bg};color:${c.text};`;
}
---

<LayoutCarrusel title="Carrusel | EdUNLu">
    <div class="carrusel-page min-h-screen flex flex-col">
        <header class="carrusel-header">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 128 128"
                class="header-logo"
                role="img"
                aria-label="Logo EdUNLu"
            >
                <g fill="#0DA353">
                    <path
                        d="M54.9 0 4.7 28.9v59.6L73.1 128l50.2-28.9L112.6 93l-39.3 22.7-25.1-14.4V79.9L29.5 90.6V43.3L72 18.7l18.4 10.7L48.2 54l24.9 14.4 50.2-28.9L54.9 0zM12.4 80.7V33.4L54.6 8.8l9.4 5.6L22 38.7V86l-9.6-5.3zM64 53.7l34.2-19.8 9.4 5.6L73.4 59.3 64 53.7z"
                    />
                    <polygon points="73.1 115.7 48.2 101.3 48.2 54 73.1 68.4" />
                </g>
            </svg>
        </header>

        <div class="swiper mySwiper">
            <div class="swiper-wrapper">
                {
                    books.map((book: Book) => (
                        <div class="swiper-slide">
                            <div class="slide-card">
                                <div class="slide-image">
                                    <img
                                        src={getImageSrc(book.coverImage)}
                                        alt={book.title}
                                        loading="lazy"
                                    />
                                </div>
                                <div class="slide-info">
                                    <h3 class="slide-title">{book.title}</h3>
                                    <span
                                        class="slide-collection"
                                        style={getCollectionStyle(
                                            book.collection,
                                        )}
                                    >
                                        {book.collection || "Sin colección"}
                                    </span>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
            <div class="swiper-pagination"></div>
        </div>
    </div>
</LayoutCarrusel>

<style>
    .carrusel-page {
        background: linear-gradient(135deg, #ffffff 0%, #ffffff 100%);
        padding: 2rem 1rem 4rem;
        color: #f1f5f9;
        font-family:
            system-ui,
            -apple-system,
            "Segoe UI",
            Roboto,
            sans-serif;
    }

    .carrusel-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .header-logo {
        width: 80px;
        height: 80px;
        margin: 0 auto;
        display: block;
    }

    .swiper {
        width: 100%;
        flex: 1;
        min-height: 0;
        padding-top: 50px;
        padding-bottom: 80px;
        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 18%,
            black 82%,
            transparent 100%
        );
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 18%,
            black 82%,
            transparent 100%
        );
    }

    .swiper-slide {
        background-position: center;
        background-size: cover;
        height: auto;
    }

    .slide-card {
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .slide-image {
        aspect-ratio: 3 / 4;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .slide-image img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
    /* filter: blur(2px); */    
        transition: filter 0.4s ease;
    }

    .swiper-slide:not(.swiper-slide-active) .slide-image img {
        filter: blur(2px);
    }

    .swiper-slide-active .slide-image img {
        filter: none;
    }
    /* filter: blur(2px); */ 
    .slide-info {
        padding: 0.85rem 0.9rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        background: #ffffff;
    }

    .slide-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e293b;
        line-height: 1.3;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 3.6em;
    }

    .slide-collection {
        display: inline-block;
        align-self: flex-start;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        letter-spacing: 0.02em;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .swiper-pagination-bullet {
        background: #94a3b8;
        opacity: 0.6;
        width: 10px;
        height: 10px;
    }

    .swiper-pagination-bullet-active {
        background: #22c55e;
        opacity: 1;
    }

    @media (max-width: 640px) {
        .swiper {
            -webkit-mask-image: none;
            mask-image: none;
        }
    }
</style>

<script>
    import Swiper from "swiper";
    import { EffectCoverflow, Pagination } from "swiper/modules";

    const swiper = new Swiper(".mySwiper", {
        modules: [EffectCoverflow, Pagination],
        effect: "coverflow",
        grabCursor: true,
        centeredSlides: true,
        slidesPerView: 5,
        spaceBetween: 30,
        loop: true,
        breakpoints: {
            0: { slidesPerView: 1.4, spaceBetween: 10 },
            640: { slidesPerView: 3, spaceBetween: 20 },
            1024: { slidesPerView: 5, spaceBetween: 30 },
        },
        coverflowEffect: {
            rotate: 50,
            stretch: 0,
            depth: 100,
            modifier: 1,
            slideShadows: true,
        },
        pagination: {
            el: ".swiper-pagination",
            dynamicBullets: true,
            dynamicMainBullets: 3,
            clickable: true,
        },
    });
</script>
